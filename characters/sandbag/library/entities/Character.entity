    {
      "$id": "326b4657-3a6a-5c40-ab07-06b607955903",
      "length": 26,
      "name": "getup_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "576273d5-4d3c-5de4-9b58-fa87c78077c2",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cad6f006-1bc1-5fef-be87-671f0f96f313",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a99ae134-c6d2-5228-a7b2-1bda965b7591",
      "code": "self.self.playSound(\"brawl_swing_m\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "96adad10-bfe9-5bf9-bf51-77d9c5f2debb",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6e3f0606-74bc-5915-a592-8bc644377491",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "38bdfb16-aa17-550e-89b9-7884b68c2b28",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f9861c93-30e2-5589-bf0e-e4797f60c960",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(3);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_m\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4d567038-04ef-542b-b119-4257380f2aa1",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
