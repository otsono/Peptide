    {
      "$id": "80325132-6ced-5b93-b377-5cb195be09cc",
      "code": "self.self.setGlobalVariable(\"crouchdown\", true);\nself.rand = 0;\nself.rand = SSF2API.randomInteger(0, 3);\nself.repeats = 0;\nself.gotoAndStop(\"blink\");\nreturn;",
