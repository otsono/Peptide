    {
      "$id": "df42765a-8195-5643-9556-0ff420b5c94b",
      "length": 21,
      "name": "item_smash",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "7a279805-8425-5596-a8f9-87e071dea598",
      "code": "self.xframe = \"attack\";\nself.self.destroyTimer(self.effects);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ebeb1edc-b563-55e4-a68e-acbf4c89b3d9",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ef8e3471-2b8b-5923-a120-5e9cab9394e4",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4d2e54db-405d-539b-b704-abf9bb0aaddf",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e3325456-42d7-57eb-8a65-0e80d9c9a222",
      "code": "self.self.getItem().deactivateItem();\nself.self.updateAttackStats({ chargetime_max: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d4313753-89dc-5451-8bb3-374e8c742cbb",
      "code": "",
      "length": 15,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3caca9d1-7e5f-51ae-8d1c-3580cbaf7dbf",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
