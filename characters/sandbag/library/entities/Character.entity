    {
      "$id": "f52ab47f-0041-50ec-9ed1-3a1d7a2bfe04",
      "length": 40,
      "name": "special_neutral",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f3329112-fdc9-5a44-9e3a-a589a6382121",
      "code": "self.self = /* ? */;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3ee632b1-34e4-5a7c-8a7b-b5474cb2b361",
      "code": "self.self.playSound(\"magic_screech\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "07c1176f-597b-59d9-a47a-ae1e85464c9d",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "717365c1-ba37-575c-89f8-54669f66a87e",
      "code": "self.self.attachEffect(\"sandbag_nspec_red\", { scaleX: 1.2, scaleY: 1.2, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f5898ce9-5edb-5ec8-87cc-bc1b7ab3f3d5",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "028bebb4-758e-5a05-81f2-b6ef424d17fe",
      "code": "self.self.attachEffect(\"sandbag_nspec_green\", { scaleX: 1.2, scaleY: 1.2, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "41b3f26e-a29a-535c-b051-55da8caf02f8",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cb9d6d7c-4456-5e39-bae8-497589d192cf",
      "code": "self.self.attachEffect(\"sandbag_nspec_blue\", { scaleX: 1.2, scaleY: 1.2, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7fefeb1e-527c-5836-b314-35f87e63e6ac",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0be2948d-cfdb-5d14-83fa-1aacc6dcc905",
      "code": "if (self.self.getItem()) {\n\tself.self.endAttack();\n\treturn;\n} else {\n\tself.self.generateItem(\"capsule\", true, false, true);\n\tself.self.playSound(\"sandbag_itemSpawn\");\n\tself.self.attachEffect(\"sandbag_confetti\", { y: -15, parentLock: false });\n\tself.self.updateAttackStats({ air_ease: 0 });\n\tself.self.resetMovement();\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "707ec389-35c0-5c06-9168-1f0bb245233f",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c3bd3ff2-638b-5b0b-8025-3b3415d8fe40",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "55d11a84-13aa-58aa-ae6f-f922d21a0eec",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
