    {
      "$id": "74123aaf-d989-5358-9f8e-02c0aa3fc1e4",
      "length": 13,
      "name": "tilt_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "a2e60ff5-2eac-5f46-9ad6-846a6483bb11",
      "code": "self.self = /* ? */;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3d0f2dea-8103-55fc-b539-3d9b76e3ef1f",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "70dc4a67-e37e-5188-aadf-a2075de4adea",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c8c3d566-7220-561f-8dc3-56c310461aa5",
      "code": "self.self.playSound(\"brawl_swing_m\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "26ea6572-bdc5-5aeb-9a1e-055764d23782",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2644a7f6-4d03-500b-ada0-8508a762f776",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(5), y: -75, parentLock: true });\nself.self.attachEffect(\"global_dust_swirl\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0c6c0577-3140-56e0-bbf5-141f44819715",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14e0e097-63fc-55ba-a0ea-a94397898ed2",
      "code": "self.self.attachEffect(\"effect_land\");\nif ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(2);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_m\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "92e5d34a-b71a-5191-b8c6-612153a78b54",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
