    {
      "$id": "67844768-2465-5dc9-82ed-5a2c47154387",
      "code": "self.self = /* ? */;\nif (self.self && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9ef04142-e2be-5ec3-a9f7-abee702508f7",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "efe09b04-f57d-5e1e-a0e2-c782322333d6",
      "code": "self.self.attachEffect(\"global_spark\", { y: -30 });\nself.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e5caae9-c9a3-557c-ab73-5fc328c79239",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0d37c32e-cac6-59c3-b8f5-6a5147b50921",
      "code": "self.self.playSound(\"brawl_swing_m\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b1db8fb1-ac8f-53fd-8173-61e1b7441aab",
      "code": "self.self.attachEffect(\"global_dust_blast\", { y: 20, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9172e86d-e6a9-5426-a44e-bc9295b9d0b0",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5bd28bc0-f4a1-567f-8275-70384da47bce",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b357f6f6-3c06-597d-bc48-3b485e60d35b",
      "code": "",
