    },
    {
      "$id": "00e6fb12-053d-56ec-bf11-56a64c9e303e",
      "length": 19,
      "name": "strong_forward_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "35f5b1ea-ef16-5d84-b665-bfeb291bb5d6",
      "code": "self.xframe = \"attack\";\nself.self.destroyTimer(self.effects);\nself.self.setIntangibility(true);\nself.self.playSound(\"fox_jumpSound\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "97e0a9ae-bd7d-50b9-ac0c-3160247d51ae",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f6c12ddb-5ae7-5f3c-a599-b1b5119bcdbc",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "db9938ec-ddc9-531d-bf9d-8fabc8b8f36e",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cc970367-806b-5d4e-9272-cf24d34cf364",
      "code": "self.self.setXSpeed(20, false);\nself.self.playSound(\"brawl_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c7a6d374-792a-5d8f-a257-e4beb750176c",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6504a96e-3cfa-5b91-9198-daeecf8f7cde",
      "code": "self.self.setXSpeed(8, false);\nself.self.attachEffect(\"global_dust_cloud\", { x: self.self.flipX(27), y: 2, scaleX: 0.75, scaleY: 0.75 });\nif ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(4);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
