      "$id": "97d20b0c-aa1b-5f58-8882-7c6ed56340c6",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "536dc560-5948-502f-840b-b67c7cea52de",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "40db236e-e38a-596f-8372-78194890c1ee",
      "code": "self.self.playSound(\"brawl_swing_m\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7e8bb57e-4409-5a72-9907-5963179bfaea",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(78), y: -50, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a372acb7-de74-58a8-86e8-8a06b55ac18e",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1aa228ab-7a95-5dbb-b3f1-08f8c0824087",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b5b8a472-7e8d-580f-9293-d61b60c0375e",
      "code": "",
