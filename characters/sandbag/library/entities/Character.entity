      "type": "LABEL"
    },
    {
      "$id": "8c22065d-f191-5c7a-9d72-0aadffe2ec84",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.playSound(\"fall_asleep\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79378026-fb68-5afb-9a2a-d0751eadd2c3",
      "code": "",
      "length": 43,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "196652ba-ff52-5eea-a9da-5356ba15086c",
      "code": "self.self.attachEffect(\"global_bubbles\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6b02114e-7217-531f-8ed1-3d6ab5284e59",
