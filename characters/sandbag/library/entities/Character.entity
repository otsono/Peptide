      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "38ed60b6-a80c-5bfa-8c42-0ab434c91e49",
      "code": "if (self.self.isOnGround()) {\n\tself.restoreSpecials(null);\n}\nself.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
