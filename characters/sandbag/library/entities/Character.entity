    },
    {
      "$id": "2157cbf2-a437-55a0-a7dc-5415e84f20fc",
      "code": "self.self = /* ? */;\nself.speed = -23;\nself.updateStats = true;\nif (SSF2API.isReady() && self.self) {\n}\n}\n\n\nfunction b_up__frame0() {\nself.self = /* ? */;\nself.item = null;\nif (self.self && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "64fd8ad5-c665-563c-adf8-87e3aef4cc81",
      "code": "self.self.setXSpeed(self.self.getXSpeed() / 2);\nself.self.playSound(\"screw1\");\nreturn;\n}\n\n\nfunction b_up__frame1() {\nif (self.self.getItem()) {\n} else {\n\treturn;\n}\nif (self.self.getItem().getItemStat(\"linkage_id\") != \"bobomb\") {\n\tself.self.tossItem(265);\n} else {\n\tself.self.stancePlayFrame(3);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bd1ef3af-3502-5357-bebe-a1e19f5010f9",
      "code": "self.self.createTimer(1, 10, self.moveUp);\nself.self.setYSpeed(-23);\nself.self.playSound(\"screw2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "282abf4d-133c-588c-92de-4d319b50c47e",
      "code": "if (self.self.getItem()) {\n} else {\n\tself.self.generateItem(\"bobomb\", true, false, true);\n\tself.item = self.self.getItem();\n\tself.item.attachEffect(\"dust\");\n\tself.self.playSound(\"link_bombappear\");\n\tself.self.addEventListener(SSF2Event.STATE_CHANGE, self.dropItem);\n\treturn;\n}\nif (self.self.getItem().getItemStat(\"linkage_id\") != \"bobomb\") {\n} else {\n\tself.item = self.self.getItem();\n\tself.self.addEventListener(SSF2Event.STATE_CHANGE, self.dropItem);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "548ad33c-bd79-59cc-b8be-034bf30f886b",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b2646985-c0fd-54ac-afcf-0d51b6594720",
      "code": "self.self.playSound(\"screw3\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "95449239-abcb-5846-89c0-4489564ca36b",
      "code": "",
