    },
    {
      "$id": "e0632bc5-683f-529a-a697-2996a66b5f3a",
      "code": "SSF2API.getCamera().shake(4);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_l\");\n\treturn;\n}\nself.self.playSound(\"itemland2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8ff2ba1a-7844-56ea-b72f-77969287f68e",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "83a686a3-2709-580f-8196-0e6fc6f8cbb1",
      "code": "self.self.setXSpeed(0);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "939b28ae-7195-5c24-8f6c-24761f88a611",
      "code": "self.self.playSound(\"fox_jumpSound\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
