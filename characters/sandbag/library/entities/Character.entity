    {
      "$id": "6015c0a5-0f6b-566c-8b7e-6f82b88d4a48",
      "length": 23,
      "name": "strong_up_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "0f2aa336-7c1d-5440-8503-84f37433c933",
      "length": 9,
      "name": "continue",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "48d5b245-408f-5713-bb22-faae4f984038",
      "code": "self.xframe = \"attack\";\nself.self.destroyTimer(self.effects);\nself.self.playSound(\"fox_jumpSound2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "789ff5fb-ff59-5b16-aef3-442030452671",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9264e89-d0a0-505c-b66e-328db5c2971e",
      "code": "self.self.setYSpeed(-15);\nself.self.attachEffect(\"global_dust_cloud\");\nself.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "46b9807e-2d79-5615-8866-23a61ebb655c",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9ab5f333-f74f-5380-ac65-0843c30252d3",
      "code": "self.self.updateAttackBoxStats(1, { weightKB: 105 });\nself.self.playSound(\"brawl_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6e710c75-44b8-522a-a199-4c280271f8fc",
      "code": "self.self.updateAttackBoxStats(1, { weightKB: 90 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3ed1e785-23c3-5c47-a724-db44c70f1352",
      "code": "self.self.updateAttackBoxStats(1, { weightKB: 60 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3e50793d-4d6f-5add-9c0c-c54a8606afac",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d55dd5ec-5780-5b4c-ab00-90e61409d55c",
      "code": "self.self.updateAttackBoxStats(1, { weightKB: 40 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "43c47771-d5c9-54d8-9288-8e4a296efa9d",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7b7dceb1-414a-518c-97fd-cb7ea3dbbf11",
      "code": "self.self.refreshAttackID();\nself.self.updateAttackStats({ canFallOff: false });\nself.self.updateAttackBoxStats(1, { direction: 55, power: 55, kbConstant: 100, weightKB: 0 });\nself.self.playSound(\"brawl_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b1ca3065-5732-5385-a756-6bc68160b02a",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4424c13a-2a5f-5c66-9ae7-6210a08e41d6",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b4a60f66-7c97-51f6-b357-31b36df6b1ea",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(4);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6aef570c-4089-52cb-87e3-09ae720770af",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
