    },
    {
      "$id": "bac5de73-5a84-55ef-a868-567b416f5c54",
      "code": "self.updateStats = false;\nself.self.updateAttackBoxStats(1, { power: 30, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackBoxStats(2, { power: 0, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackStats({ refreshRate: 1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c9dbf8cb-62c6-5a02-8c58-bdb2f2f655b9",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2d7aef1b-5399-57f2-bb77-ca9d431f9035",
      "code": "self.self.playSound(\"screw4\");\nself.self.setIASA(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e07b565f-995c-587c-ad6f-8513e61e014d",
      "code": "self.self.updateAttackBoxStats(1, { power: 80, kbConstant: 100, damage: 2, hitStun: 5, selfHitStun: 5 });\nself.self.updateAttackBoxStats(2, { power: 80, kbConstant: 100, damage: 2, hitStun: 5, selfHitStun: 5 });\nself.self.updateAttackStats({ refreshRate: 90 });\nself.self.refreshAttackID();\nreturn;\n}\n\n\nfunction b_up__frame11() {\nself.self.attachEffect(\"global_dust_swirl\");\nif (self.item) {\n\tself.item.addEventListener(SSF2Event.ATTACK_CONNECT, self.self.toHelpless);\n\tself.item.toToss();\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
