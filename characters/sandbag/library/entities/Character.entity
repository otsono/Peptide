    },
    {
      "$id": "228da355-4fb5-52f6-9465-ba36f80cc11f",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}\n}\n\n\nfunction tech_roll__frame0() {\nself.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4587ef31-9fc9-53ab-b87d-bd9d4fa7794b",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "478687ae-1327-5b63-843a-4786bb9e3b2a",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "50f0bef6-b673-5e27-950d-e8ea69877474",
      "code": "self.self.setIntangibility(false);\nreturn;",
