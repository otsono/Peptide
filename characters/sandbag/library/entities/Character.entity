    {
      "$id": "2b351f84-2da2-5029-996c-77dafa626f94",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(3);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
