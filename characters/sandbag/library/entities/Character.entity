    },
    {
      "$id": "9eea3ac6-aad8-5d06-bdf2-e85736c5e6d7",
      "code": "self.self.setXSpeed(5, false);\nself.self.attachEffect(\"global_dust_light\");\nself.self.playSound(\"link_step\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9a56a13b-8c6b-52ca-892d-70fef6f28fbb",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7f00c4b0-d40a-5ca3-85b5-d3605886779c",
      "code": "self.self.setXSpeed(1, false);\nself.self.attachEffect(\"effect_land\");\nSSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_l1\");\n\treturn;\n}\nself.self.playSound(\"itemland2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fdf5877a-18b8-5137-9042-d15894273b9b",
      "code": "",
      "length": 1,
