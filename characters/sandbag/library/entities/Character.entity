      "$id": "106d2f31-bd42-5b73-9bad-c96074c7a4ed",
      "length": 18,
      "name": "dashright",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "68c4e454-2808-53fb-b816-a731c52eea3a",
      "length": 18,
      "name": "dashup",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "582e20e0-bbed-5664-9759-eadbf2412a8c",
      "code": "self.self = /* ? */;\nself.controls = null;\nself.dir = null;\nself.leftSpeed = -15;\nself.rightSpeed = 15;\nself.upSpeed = -20;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6815cc5-cc2d-54a5-9e85-f1524ffe6f82",
      "code": "self.self.setAttackEnabled(false, \"b_down\");\nself.self.setAttackEnabled(false, \"b_down_air\");\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.restoreSpecials, { persistent: true });\nself.self.addEventListener(SSF2Event.CHAR_HURT, self.restoreSpecials, { persistent: true });\nself.self.addEventListener(SSF2Event.CHAR_GRABBED, self.restoreSpecials, { persistent: true });\nself.self.addEventListener(SSF2Event.CHAR_LEDGE_GRAB, self.restoreSpecials, { persistent: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d119bf41-4ad6-5e0e-8976-259d0e129bd1",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "437f35a1-01a5-5fde-9e9d-5356daaa2e51",
      "code": "self.self.createTimer(1, 0, self.dashCheck);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2b9cf290-af5a-5e36-ae8d-37f190199200",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9c1b95cc-5c5a-5c45-9195-4807dd9b9031",
      "code": "self.self.destroyTimer(self.dashCheck);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d01524d3-9b84-58ab-8441-b88d5d0f3a6e",
      "code": "self.self.updateAttackStats({ air_ease: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ca8d6f5c-cdb4-5d8d-bdf1-63d50414358c",
      "code": "",
      "length": 8,
