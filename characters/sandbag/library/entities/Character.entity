    },
    {
      "$id": "485fd54a-1d93-5755-85d1-4c3e0ef9196b",
      "code": "self.self = /* ? */;\nif (self.self && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5382fa19-63ee-5a86-a28d-15e319de4a45",
      "code": "self.self.setXSpeed(14, false);\nself.self.attachEffect(\"global_dust_heavy\");\nself.self.playSound(\"sw_brawl_swing_H\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a622aebe-881a-54a0-bc2f-aab7f2c508ec",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23ec7eaf-8e0b-52fc-859f-dcfaf4de506c",
      "code": "self.self.setXSpeed(5, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "86a13617-101c-5179-b718-8b6009390df9",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(1);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_m\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "29937add-7d8e-510d-a8ca-0d3e1f725bd8",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d5d95fae-37c9-5fa9-8969-295901ebc19d",
      "code": "self.self.setXSpeed(0);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf94954e-5f80-5507-8cff-1f92598696c0",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
