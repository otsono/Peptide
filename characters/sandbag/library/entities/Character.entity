    },
    {
      "$id": "4b689db4-4397-5656-8847-c6e079780c5b",
      "length": 8,
      "name": "landing",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "eb2bb410-dedc-52a5-9337-e0f90d93a7e3",
      "code": "self.self = /* ? */;\nself.charGrabbed = false;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c66fc288-9a49-5483-a024-ee234ce88c20",
      "code": "self.self.addEventListener(SSF2Event.CHAR_GRAB, self.toContinue);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1274f448-6df7-51e3-8405-f20b408bd4cc",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ef25e6d8-ff76-50ce-9807-d005c536d94b",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "43d125e4-0adc-5929-8726-c802700e2ad2",
      "code": "self.self.setXSpeed(13, false);\nself.self.setYSpeed(-11);\nself.self.playSound(\"bowser_swing5\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f80ded68-9352-5549-8c2e-18a72ca4a41f",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "183ad1ba-fcf8-5f21-8ecc-84b17d36ac52",
      "code": "self.self.updateAttackBoxStats(1, { damage: 6 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "804876b1-92fe-5c5e-b440-95785ccaade2",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "81fb47fa-094b-5d86-8e2b-2f22edf5b590",
      "code": "if (self.self.isOnGround()) {\n\tself.self.stancePlayFrame(\"continue\");\n}\nself.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e02a2cd9-959c-5ef7-8595-7eb2bd757bc5",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "031b735c-d45b-595d-aa9d-f0789f7025de",
      "code": "self.self.setXSpeed(self.self.getXSpeed() * 0.6);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1552d6c6-cdd0-5266-bbbb-e2e95904cd6b",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f4e71566-0047-5c4f-9a79-81827ea12c5b",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8a62a2b9-2644-5041-9779-127566331b83",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9e48312f-c892-509c-83d2-db4afb132b4b",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b89df544-db6c-5b1d-8125-eae5ea7d84da",
      "code": "self.self.setXSpeed(self.self.getXSpeed() / 2);\nself.self.setYSpeed(self.self.getYSpeed() / 2);\nself.self.swapDepthsWithGrabbedOpponent(true);\nself.self.attachEffect(\"global_dust_cloud\");\nself.self.updateAttackStats({ cancelWhenAirborne: false });\nif (self.self.isOnGround()) {\n\tself.self.playSound(\"grab\");\n\treturn;\n}\nself.self.playSound(\"itemland2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "17dcb494-e54b-578b-a543-7ea2409305d8",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "487e447b-2b71-5f91-a2e9-9522cb2d986c",
      "code": "self.self.setXSpeed(8, false);\nif (self.charGrabbed) {\n\tself.self.setYSpeed(-15);\n\tself.self.updateAttackStats({ air_ease: 2 });\n\tself.self.attachEffect(\"global_dust_heavy\");\n\treturn;\n}\nself.self.setYSpeed(-7);",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f6ccd00-2e60-548b-8757-30157caadfa6",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "99d79300-3f8e-5a82-975c-9aa0569bdfbe",
      "code": "if (self.charGrabbed == false && self.self.isOnGround()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cac6a641-9476-544e-8502-a9b8a2fb1356",
      "code": "if (self.charGrabbed == false && self.self.isOnGround()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2d4b4cb7-08fd-5067-a446-197b0aff9384",
      "code": "if (self.charGrabbed == false && self.self.isOnGround()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ceae0af3-1752-5953-a5e8-cf18277d5cf2",
      "code": "if (self.self.isOnGround()) {\n\tself.self.stancePlayFrame(\"landing\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b967f664-de11-5c80-bfe1-97b8e5169c1b",
      "code": "if (self.self.isOnGround()) {\n\tself.self.stancePlayFrame(\"landing\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a40add9e-f612-507c-b5f6-781dd70916e6",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nif (self.self.isOnGround()) {\n\tself.self.toLand();\n}\nself.self.setLandingLag(false);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cdd60da7-526c-58ab-87c5-fa8d399081f1",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a9901b95-83fa-5f31-8ace-bbd08a6352f9",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6787ab27-ea64-5b35-ac85-8c8b485dda40",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(3);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"itemland2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
