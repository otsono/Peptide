{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./tools/hooks/post-build-makeapp.sh",
            "timeout": 180,
            "statusMessage": "Refreshing Peptide.app bundle…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "./tools/hooks/docs-guard.sh"
          }
        ]
      }
    ]
  }
}
